# =============================================================================
# cc-websearch Configuration Template
# =============================================================================
#
# Copy this file to ~/.config/websearch/config.json and adjust values.
# All fields are optional -- see defaults below.
#
# Environment variables override config file values, which override hardcoded
# defaults. Precedence: env var > config file > hardcoded default.
#
# =============================================================================
# Section 1: Config file (~/.config/websearch/config.json)
# =============================================================================
#
# {
#   "retry": {
#     "maxRetries": 4,     # integer, 0+, max retry attempts (default: 4)
#     "baseDelay": 1000,   # integer ms, 0+, initial backoff delay (default: 1000)
#     "maxDelay": 16000,   # integer ms, 0+, maximum backoff delay (default: 16000)
#     "timeout": 30000     # integer ms, 0+, request timeout (default: 30000)
#   },
#   "logging": {
#     "level": "info"      # enum: "debug" | "info" | "warn" | "error" (default: "info")
#   }
# }

# =============================================================================
# Section 2: Environment variable overrides
# =============================================================================
#
# Set any of these to override the corresponding config file value (or
# hardcoded default if no config file exists).
#
# WEBSEARCH_RETRY_MAX_RETRIES  # integer, 0+, max retry attempts
# WEBSEARCH_RETRY_BASE_DELAY    # integer ms, 0+, initial backoff delay
# WEBSEARCH_RETRY_MAX_DELAY     # integer ms, 0+, maximum backoff delay
# WEBSEARCH_RETRY_TIMEOUT       # integer ms, 0+, request timeout
# WEBSEARCH_LOGGING_LEVEL       # enum: "debug" | "info" | "warn" | "error"
